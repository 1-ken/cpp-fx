# ---- cTrader Open API credentials -----------------------------------------
# Obtained from https://openapi.ctrader.com (Application) + OAuth2 flow.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
# Numeric ctidTraderAccountId of the trading account to stream.
CTRADER_ACCOUNT_ID=
# "live" or "demo" (overrides config.json ctrader.host)
CTRADER_HOST=live

# ---- HTTP server ----------------------------------------------------------
PORT=8000
# Optional explicit WebSocket URL advertised to the frontend via /client-config and /me
WS_URL=
API_BASE_URL=

# ---- Auth (NextAuth-compatible HS256 JWT) ---------------------------------
NEXTAUTH_SECRET=
# Set to 1/true to disable auth (development only — no JWT required in Postman)
AUTH_DISABLED=1

# Admin OTP login (SMS to this phone; must match admin panel input)
ADMIN_PHONE=+254707879716
OTP_TTL_SECONDS=300

# Browser CORS origin for direct admin API calls from the Next.js app
CORS_ALLOW_ORIGIN=http://localhost:3000

# ---- PostgreSQL -----------------------------------------------------------
# libpq DSN for Drogon (postgresql:// only; postgresql+asyncpg:// is auto-normalized).
# Must point at a real database. On each startup the server runs versioned migrations
# before accepting HTTP traffic; auth/user endpoints return 503 until migrations succeed.
DATABASE_URL=postgresql://user:password@localhost:5432/observer

# ---- Redis ----------------------------------------------------------------
# Managed Redis (hostname OK — resolved at startup): redis://default:password@your-redis-host:6379
REDIS_URL=redis://localhost:6379/0
REDIS_PUBSUB_ENABLED=true

# ---- Notification providers (optional) ------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@example.com

SMS_GATE_USERNAME=
SMS_GATE_PASSWORD=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
