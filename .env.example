# ---- cTrader Open API credentials -----------------------------------------
# Obtained from https://openapi.ctrader.com (Application) + OAuth2 flow.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
# Numeric ctidTraderAccountId of the trading account to stream.
CTRADER_ACCOUNT_ID=
# "live" or "demo" (overrides config.json ctrader.host)
CTRADER_HOST=live

# ---- HTTP server ----------------------------------------------------------
PORT=8000
# Optional explicit WebSocket URL advertised to the frontend via /client-config and /me
WS_URL=
API_BASE_URL=

# ---- Auth (NextAuth-compatible HS256 JWT) ---------------------------------
NEXTAUTH_SECRET=
# Set to 1/true to disable auth (development only — no JWT required in Postman)
AUTH_DISABLED=1

# ---- PostgreSQL -----------------------------------------------------------
# libpq style DSN, e.g. postgresql://user:password@localhost:5432/observer
DATABASE_URL=postgresql://user:password@localhost:5432/observer

# ---- Redis ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PUBSUB_ENABLED=true

# ---- Notification providers (optional) ------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@example.com

AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
