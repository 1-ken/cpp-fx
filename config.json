{
  "ctrader": {
    "host": "live",
    "liveHost": "live.ctraderapi.com",
    "demoHost": "demo.ctraderapi.com",
    "port": 5035,
    "heartbeatIntervalSeconds": 10,
    "reconnectBaseDelaySeconds": 1.0,
    "reconnectMaxDelaySeconds": 30.0,
